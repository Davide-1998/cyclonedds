#ifndef DDS_LIBRARY_LOADER_H
#define DDS_LIBRARY_LOADER_H

#include <stdio.h>
#include <stdlib.h>

// TODO // Create a general-purpose file with these functions to avoid code
// duplication. There is one in ddsrt already implemented, but having DDSRT
// symbols being tested in symbol_export.c it makes no sense to use them.

// Libraries filepaths that will be used when testing that the symbols have been
// exported
const char *DDSC_LIBRARY_NAME = "@DDSC_LIBRARY_FILEPATH@";
const char *CDR_LIBRARY_NAME = "@CDR_LIBRARY_FILEPATH@";

// Struct representing a loaded library
typedef struct dds_loaded_library {
  void *handle;     // Pointer to the loaded library handle
  const char *name; // Name of the library, mainly used in error messages
} dds_loaded_library_t;

#if WIN32
#define WIN32_LEAN_AND_MEAN
#include <windows.h> // Windows shared library loader API

// Use function pointers to ensure cross-platform functionalities
HMODULE(WINAPI *load_library)(LPCSTR) = &LoadLibrary;
BOOL(WINAPI *close_library)(HMODULE) = &FreeLibrary;
FARPROC(WINAPI *resolve_library_symbol)(HMODULE,
                                        const char *) = &GetProcAddress;

#else // WIN32

#include <dlfcn.h> // Unix Shared library loader API

// Function pointers for the Unix OS
void *(*load_library)(const char *, int) = &dlopen;
int (*close_library)(void *) = &dlclose;
void *(*resolve_library_symbol)(void *, const char *) = &dlsym;

#endif // WIN32

// Library loading implementation ensuring correct flags are always provided
// when loading a shared library
void cyclonedds_load_library(dds_loaded_library_t *library,
                             const char *library_filepath) {
  library->handle = load_library(library_filepath);
  library->name = library_filepath;
  if (library->handle == NULL) {
    printf("Unable to load %s library\n", library->name);
  }
}

/**
 * @brief Function used to check that a symbol in the DDSC library is being
 * exported
 *
 * @param result Pointer to integer variable representing check return value
 * @param library Loaded library structure
 * @param symbol String representing the symbol name to be checked
 */
static void check_symbol_export(int *result, dds_loaded_library_t *library,
                                const char *symbol) {
  void *symbol_address = resolve_library_symbol(library->handle, symbol);
  if (symbol_address == NULL) {
    printf("Symbol '%s' does not exist in '%s'\n", symbol, library->name);
    *result = EXIT_FAILURE;
  }
}

#endif // DDS_LIBRARY_LOADER_H